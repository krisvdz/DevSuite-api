# ═══════════════════════════════════════════════════════════════════════════
# VARIÁVEIS DE AMBIENTE — Copie este arquivo para .env e preencha os valores
# ═══════════════════════════════════════════════════════════════════════════
#
# 📚 CONCEITO: Variáveis de Ambiente
#
# Por que não hardcodar configurações no código?
# 1. Segurança: credenciais não vão para o Git (repositório público!)
# 2. Flexibilidade: a mesma codebase roda em dev/staging/produção com configs diferentes
# 3. 12-Factor App: princípio #3 da metodologia de apps cloud-native
#
# .env           → valores locais (NUNCA commitar, está no .gitignore)
# .env.example   → template com as variáveis necessárias (commitar — sem valores reais!)
# .env.test      → valores para ambiente de testes
#
# Em produção: configure via painel da plataforma (Railway, Heroku, etc.)
# ou via secrets no GitHub Actions/Kubernetes.

# ─── Servidor ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Banco de Dados ───────────────────────────────────────────────────────────
# PostgreSQL connection string
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Com Docker: postgresql://postgres:postgres@localhost:5432/taskflow
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskflow?schema=public"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Chave secreta para assinar tokens JWT
# Em produção: use uma string aleatória longa (min 32 chars)
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="sua-chave-super-secreta-aqui-minimo-32-caracteres"
JWT_EXPIRES_IN="7d"

# ─── CORS ────────────────────────────────────────────────────────────────────
# Origens permitidas (separadas por vírgula se houver mais de uma)
CORS_ORIGIN="http://localhost:5173"
